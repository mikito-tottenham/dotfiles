#!/bin/sh
set -eu

command="restore"
manifest_item="${OP_DOTFILES_MATERIALIZE_ITEM:-Secrets Manifest}"
manifest_vault="${OP_DOTFILES_MATERIALIZE_VAULT:-Dotfiles Secrets}"
manifest_file="${OP_DOTFILES_MATERIALIZE_FILE:-}"
field_label="${OP_DOTFILES_MATERIALIZE_FIELD_LABEL:-content}"
work_dir="${OP_DOTFILES_MATERIALIZE_WORK_DIR:-$HOME/.config/op/injected}"
force=false
add_item=""
add_out_path=""
add_mode="0600"
add_vault="${OP_DOTFILES_MATERIALIZE_VAULT:-Dotfiles Secrets}"

usage() {
  cat >&2 <<'EOF'
usage:
  opmaterialize diff [--manifest <path>] [--manifest-item <name>] [--manifest-vault <vault>]
  opmaterialize restore [--force] [--manifest <path>] [--manifest-item <name>] [--manifest-vault <vault>]
  opmaterialize add <file> [--vault <vault>] [--item <name>] [--out-path <path>] [--mode <mode>] [--manifest-item <name>] [--manifest-vault <vault>]

diff:
  Read the manifest and compare declared 1Password secret files with local
  files without printing secret contents or writing target files.

restore:
  Read a tab-separated manifest from the Secure Note "Secrets Manifest"
  (notesPlain field) and materialize declared files into their paths.

add:
  Save a local file as a 1Password Document, then add or update the matching
  row in "Secrets Manifest". 'add' is document-based; against a field-based
  (Secure Note) manifest it refuses, so register field-based secrets manually.

Manifest columns:
  type    item    out_path    mode    vault

Manifest 'type' values:
  document  a 1Password Document item (file body)
  field     a Secure Note field (default label 'content', override with
            OP_DOTFILES_MATERIALIZE_FIELD_LABEL)
EOF
}

if [ "$#" -gt 0 ]; then
  case "$1" in
    diff|restore|add)
      command="$1"
      shift
      ;;
  esac
fi

source_file=""
if [ "$command" = "add" ]; then
  if [ "$#" -lt 1 ]; then
    usage
    exit 64
  fi
  source_file="$1"
  shift
fi

while [ "$#" -gt 0 ]; do
  case "$1" in
    --force)
      force=true
      shift
      ;;
    --manifest)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      manifest_file="$2"
      shift 2
      ;;
    --manifest-item)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      manifest_item="$2"
      shift 2
      ;;
    --manifest-vault)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      manifest_vault="$2"
      shift 2
      ;;
    --vault)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      add_vault="$2"
      shift 2
      ;;
    --item)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      add_item="$2"
      shift 2
      ;;
    --out-path)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      add_out_path="$2"
      shift 2
      ;;
    --mode)
      if [ "$#" -lt 2 ]; then
        usage
        exit 64
      fi
      add_mode="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 64
      ;;
  esac
done

if ! command -v op >/dev/null 2>&1; then
  printf '%s\n' "opmaterialize: 1Password CLI 'op' is not installed or not in PATH" >&2
  exit 127
fi

# Restrict permissions on every file/dir this script creates. op read --out-file
# has no --file-mode, so without this a secret body or the manifest could exist
# briefly as group/world-readable before the explicit chmod below.
umask 077

mkdir -p "$work_dir"

expand_home() {
  case "$1" in
    "\$HOME"/*)
      printf '%s/%s\n' "$HOME" "${1#\$HOME/}"
      ;;
    '~'/*)
      printf '%s/%s\n' "$HOME" "${1#\~/}"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

home_path() {
  case "$1" in
    "$HOME"/*)
      printf "\$HOME/%s\n" "${1#"$HOME"/}"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

manifest_item_category() {
  # Print the 1Password category of the manifest item (e.g. DOCUMENT or
  # SECURE_NOTE), or nothing if it cannot be determined. Parsed without jq so
  # the 'add' guard never fails open when jq is absent.
  [ -n "$manifest_vault" ] || return 0
  op item get "$manifest_item" --vault "$manifest_vault" --format json 2>/dev/null \
    | sed -n 's/.*"category"[[:space:]]*:[[:space:]]*"\([A-Z_]*\)".*/\1/p' \
    | head -n1
}

download_manifest() {
  destination="$1"
  if [ -n "$manifest_file" ]; then
    if [ ! -r "$manifest_file" ]; then
      printf '%s\n' "opmaterialize: manifest not readable: $manifest_file" >&2
      exit 66
    fi
    cp "$manifest_file" "$destination"
    return 0
  fi

  if [ -z "$manifest_vault" ]; then
    printf '%s\n' "opmaterialize: a vault is required to read the manifest (set OP_DOTFILES_MATERIALIZE_VAULT or pass --manifest-vault)" >&2
    exit 64
  fi
  if [ "$(manifest_item_category)" = "DOCUMENT" ]; then
    # Backward-compatible Document manifest.
    op document get "$manifest_item" --vault "$manifest_vault" --out-file "$destination" --file-mode 0600 --force >/dev/null
  else
    # Default: the manifest is the notesPlain field of a Secure Note item.
    op read "op://$manifest_vault/$manifest_item/notesPlain" --out-file "$destination" --no-newline --force >/dev/null
    chmod 0600 "$destination"
  fi
}

process_manifest() {
  action="$1"
  manifest="$work_dir/secrets-manifest.tsv"
  download_manifest "$manifest"

  line_no=0
  changed=0
  differences=0
  # shellcheck disable=SC2094
  while IFS="$(printf '\t')" read -r kind item out_path file_mode vault rest || [ -n "${kind:-}" ]; do
    line_no=$((line_no + 1))

    case "${kind:-}" in
      ''|'#'*)
        continue
        ;;
    esac

    if [ -n "${rest:-}" ] || [ -z "${item:-}" ] || [ -z "${out_path:-}" ] || [ -z "${file_mode:-}" ]; then
      rm -f "$manifest"
      printf '%s\n' "opmaterialize: invalid manifest row $line_no" >&2
      exit 65
    fi

    target="$(expand_home "$out_path")"
    target_dir="$(dirname "$target")"
    tmp="$work_dir/materialize.$$.$line_no"
    mkdir -p "$target_dir"

    case "$kind" in
      document)
        if [ "${vault:-}" = "-" ] || [ -z "${vault:-}" ]; then
          op document get "$item" --out-file "$tmp" --file-mode "$file_mode" --force >/dev/null
        else
          op document get "$item" --vault "$vault" --out-file "$tmp" --file-mode "$file_mode" --force >/dev/null
        fi
        ;;
      field)
        if ! command -v jq >/dev/null 2>&1; then
          rm -f "$manifest" "$tmp"
          printf '%s\n' "opmaterialize: 'jq' is required to materialize type=field rows" >&2
          exit 127
        fi
        row_vault="$vault"
        if [ "${row_vault:-}" = "-" ] || [ -z "${row_vault:-}" ]; then
          row_vault="$manifest_vault"
        fi
        if [ -z "$row_vault" ]; then
          rm -f "$manifest" "$tmp"
          printf '%s\n' "opmaterialize: a vault is required for type=field row $line_no" >&2
          exit 65
        fi
        # Item titles can contain '/', which is unsafe in an op:// path, so
        # resolve the immutable item id first and reference the field by id.
        item_id="$(op item get "$item" --vault "$row_vault" --format json | jq -r '.id // empty')"
        if [ -z "$item_id" ]; then
          rm -f "$manifest" "$tmp"
          printf '%s\n' "opmaterialize: cannot resolve type=field item on row $line_no: $item" >&2
          exit 65
        fi
        op read "op://$row_vault/$item_id/$field_label" --out-file "$tmp" --no-newline --force >/dev/null
        ;;
      *)
        rm -f "$manifest" "$tmp"
        printf '%s\n' "opmaterialize: unsupported type '$kind' on row $line_no" >&2
        exit 65
        ;;
    esac

    chmod "$file_mode" "$tmp"

    if [ "$action" = "diff" ]; then
      if [ ! -e "$target" ]; then
        differences=$((differences + 1))
        rm -f "$tmp"
        printf '%s\n' "missing: $target"
        continue
      fi
      if cmp -s "$tmp" "$target"; then
        rm -f "$tmp"
        printf '%s\n' "unchanged: $target"
        continue
      fi
      differences=$((differences + 1))
      rm -f "$tmp"
      printf '%s\n' "changed: $target"
      continue
    fi

    if [ -e "$target" ] && cmp -s "$tmp" "$target"; then
      rm -f "$tmp"
      printf '%s\n' "unchanged: $target"
      continue
    fi

    if [ -e "$target" ] && [ "$force" != true ]; then
      rm -f "$manifest" "$tmp"
      printf '%s\n' "opmaterialize: target differs, rerun with --force to replace: $target" >&2
      exit 73
    fi

    mv "$tmp" "$target"
    chmod "$file_mode" "$target"
    changed=$((changed + 1))
    printf '%s\n' "updated: $target"
  done < "$manifest"

  rm -f "$manifest"
  if [ "$action" = "diff" ]; then
    printf '%s\n' "complete: $differences difference(s)"
    if [ "$differences" -gt 0 ]; then
      exit 1
    fi
    return 0
  fi

  printf '%s\n' "complete: $changed file(s) updated"
}

update_manifest_file() {
  manifest="$1"
  next_manifest="$2"
  item="$3"
  out_path="$4"
  mode="$5"
  vault="$6"

  awk -F '\t' -v OFS='\t' \
    -v item="$item" \
    -v out_path="$out_path" \
    -v mode="$mode" \
    -v vault="$vault" '
      BEGIN { updated = 0 }
      /^#/ || NF == 0 { print; next }
      $2 == item || $3 == out_path {
        if (!updated) {
          print "document", item, out_path, mode, vault
          updated = 1
        }
        next
      }
      { print }
      END {
        if (!updated) {
          print "document", item, out_path, mode, vault
        }
      }
    ' "$manifest" > "$next_manifest"
}

upload_manifest() {
  manifest="$1"
  if [ "$manifest_exists" = true ]; then
    if [ -n "$manifest_vault" ]; then
      op document edit "$manifest_item" "$manifest" --vault "$manifest_vault" --file-name "secrets-manifest.tsv" --title "$manifest_item" >/dev/null
    else
      op document edit "$manifest_item" "$manifest" --file-name "secrets-manifest.tsv" --title "$manifest_item" >/dev/null
    fi
  else
    if [ -n "$manifest_vault" ]; then
      op document create "$manifest" --vault "$manifest_vault" --file-name "secrets-manifest.tsv" --title "$manifest_item" >/dev/null
    else
      op document create "$manifest" --file-name "secrets-manifest.tsv" --title "$manifest_item" >/dev/null
    fi
  fi
}

add_file() {
  if [ ! -r "$source_file" ]; then
    printf '%s\n' "opmaterialize: file not readable: $source_file" >&2
    exit 66
  fi
  # 'add' is document-based. Refuse before creating anything when the manifest
  # item exists and is NOT a Document (field-based Secure Note), so we neither
  # orphan a Document nor half-update the manifest. The category probe does not
  # need jq, so this guard never fails open. A missing manifest (first-time add)
  # yields an empty category and is allowed. Field-mode 'add' is a follow-up.
  if [ -n "$manifest_vault" ]; then
    manifest_category="$(manifest_item_category)"
    if [ -n "$manifest_category" ] && [ "$manifest_category" != "DOCUMENT" ]; then
      printf '%s\n' "opmaterialize: 'add' is document-based but manifest '$manifest_item' is '$manifest_category' (field-based vault)." >&2
      printf '%s\n' "opmaterialize: register the secret as a Secure Note '$field_label' field plus a 'field' manifest row manually, or extend 'add' for field mode." >&2
      exit 64
    fi
  fi
  source_abs="$(cd "$(dirname "$source_file")" && pwd)/$(basename "$source_file")"
  if [ -z "$add_out_path" ]; then
    add_out_path="$(home_path "$source_abs")"
  fi
  if [ -z "$add_item" ]; then
    add_item="dotfiles:${add_out_path}"
  fi
  if [ -z "$manifest_vault" ]; then
    manifest_vault="$add_vault"
  fi

  if op document edit "$add_item" "$source_abs" --vault "$add_vault" --file-name "$(basename "$source_abs")" --title "$add_item" >/dev/null 2>&1; then
    printf '%s\n' "updated document: $add_item"
  else
    op document create "$source_abs" --vault "$add_vault" --file-name "$(basename "$source_abs")" --title "$add_item" >/dev/null
    printf '%s\n' "created document: $add_item"
  fi

  manifest="$work_dir/secrets-manifest.tsv"
  next_manifest="$work_dir/secrets-manifest.next.tsv"
  manifest_exists=true
  if ! download_manifest "$manifest" >/dev/null 2>&1; then
    manifest_exists=false
    printf '# type\titem\tout_path\tmode\tvault\n' > "$manifest"
  fi

  update_manifest_file "$manifest" "$next_manifest" "$add_item" "$add_out_path" "$add_mode" "$add_vault"
  upload_manifest "$next_manifest"
  rm -f "$manifest" "$next_manifest"
  printf '%s\n' "updated manifest: $manifest_item"
}

case "$command" in
  diff)
    process_manifest diff
    ;;
  restore)
    process_manifest restore
    ;;
  add)
    add_file
    ;;
esac
